# ============================================================
# LOCAL DEVELOPMENT — leave these empty to run without auth
# ============================================================
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# ============================================================
# PRODUCTION — set these to enable Supabase auth
# ============================================================
# VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# ============================================================
# Backend API (when frontend talks to a different host, e.g. Render)
# ============================================================
# VITE_API_URL=https://ernesto-w0b2.onrender.com
